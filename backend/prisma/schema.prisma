generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Use PostgreSQL in production. Set `DATABASE_URL` in your environment (Railway provides one).
  // For local development you can use a local Postgres or switch to SQLite by adjusting this file.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Achievement {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  year        Int
  medal       String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tournament {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  date        DateTime
  location    String
  result      String?
  imageUrl    String?
  isFuture    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sponsor {
  id        Int      @id @default(autoincrement())
  name      String
  website   String?
  logoUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  location    String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrainingSchedule {
  id           Int      @id @default(autoincrement())
  dayOfWeek    String
  startTime    String
  endTime      String
  location     String
  mapUrl       String?
  requirements String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
